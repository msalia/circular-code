{
  "name": "circular-code",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.2.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && node scripts/resolve-aliases.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-dataset": "rm -rf dataset/images dataset/labels && node dist/scripts/generateDataset.js",
    "train": "node dist/scripts/trainModel.js",
    "typecheck": "npx tsc --noEmit",
    "example:build": "node example/build.js",
    "example": "node example/build.js && node example/serve.js"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "canvas": "^3.2.3",
    "react": "^19.2.5"
  }
}
